<mah:MetroWindow
	x:Class="ShipDataViewer.Ui.ShellView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="clr-namespace:ShipDataViewer.Ui"
	xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
	xmlns:s="https://github.com/canton7/Stylet"
	Title="Ship Data Viewer"
	Loaded="Window_Loaded">
	<DockPanel>
		<StatusBar DockPanel.Dock="Bottom">
			<StatusBarItem>
				<TextBlock Text="{Binding LoadingMessage}" />
			</StatusBarItem>
		</StatusBar>

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition />
			</Grid.RowDefinitions>
			<Button
				Grid.Row="0"
				Command="{s:Action StartListening}"
				Content="Start listening" />
			<Button
				Grid.Row="1"
				Command="{s:Action StopListening}"
				Content="Stop listening" />
			<TextBox
				Grid.Row="2"
				Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
				TextChanged="TextBox_TextChanged" />
			<DataGrid
				x:Name="ShipDataGrid"
				Grid.Row="3"
				AutoGenerateColumns="True"
				IsReadOnly="True"
				ItemsSource="{Binding Ships}" />
		</Grid>
	</DockPanel>
</mah:MetroWindow>
