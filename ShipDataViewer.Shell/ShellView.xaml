<ui:FluentWindow
	x:Class="ShipDataViewer.Shell.ShellView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="clr-namespace:ShipDataViewer.Shell"
	xmlns:s="https://github.com/canton7/Stylet"
	xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
	Loaded="Window_Loaded">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<ui:TitleBar Title="Ship Data Viewer" Grid.Row="0" />

		<Grid Grid.Row="1">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<ui:Card Grid.Row="0" Margin="8">
				<StackPanel Orientation="Horizontal">
					<local:Gadget
						AccentBrush="Salmon"
						Label="Ships reported"
						Value="{Binding ShipCount}" />

					<local:Gadget
						Margin="20,0"
						AccentBrush="BlueViolet"
						Label="Last update"
						Value="{Binding LastUpdateReceivedString}" />

					<StackPanel Orientation="Vertical">
						<ui:Button
							Margin="0,10"
							Command="{s:Action StartListeningAsync}"
							Content="Start listening" />
						<ui:Button
							Margin="0,10"
							Command="{s:Action StopListeningAsync}"
							Content="Stop listening" />
					</StackPanel>
				</StackPanel>
			</ui:Card>

			<ui:TextBox
				Grid.Row="1"
				PlaceholderText="Search ship MMSI, Imo Number, Name or Call Sign..."
				Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
				TextChanged="TextBox_TextChanged" />
			<DataGrid
				x:Name="ShipDataGrid"
				Grid.Row="2"
				AutoGenerateColumns="False"
				IsReadOnly="True"
				ItemsSource="{Binding Ships}">
				<DataGrid.Columns>
					<DataGridTextColumn Binding="{Binding Mmsi}" Header="Mmsi" />
					<DataGridTextColumn Binding="{Binding ImoNumber}" Header="Imo number" />
					<DataGridTextColumn Binding="{Binding Name}" Header="Name" />
					<DataGridTextColumn Binding="{Binding CallSign}" Header="Call sign" />
					<DataGridTextColumn Binding="{Binding LastReportedPosition.Latitude, StringFormat={}{0:0.000}}" Header="Latitude" />
					<DataGridTextColumn Binding="{Binding LastReportedPosition.Longitude, StringFormat={}{0:0.000}}" Header="Longitude" />
					<DataGridTextColumn Binding="{Binding LastReportedPosition.Sog, StringFormat={}{0:0.000}}" Header="Sog" />
					<DataGridTextColumn Binding="{Binding LastReportedPosition.Cog, StringFormat={}{0:0.000}}" Header="Cog" />
					<DataGridTextColumn Binding="{Binding LastReportedPosition.TrueHeading}" Header="True heading" />
					<DataGridTextColumn Binding="{Binding LastUpdated, StringFormat={}{0:G}}" Header="Last updated" />
				</DataGrid.Columns>
			</DataGrid>
		</Grid>

		<StatusBar Grid.Row="2">
			<StatusBarItem>
				<TextBlock Text="{Binding LoadingMessage}" />
			</StatusBarItem>
			<Separator />
			<StatusBarItem>
				<TextBlock Text="{Binding ShipsReportedMessage}" />
			</StatusBarItem>
			<Separator />
			<StatusBarItem>
				<TextBlock Text="{Binding LastUpdateMessage}" />
			</StatusBarItem>
		</StatusBar>
	</Grid>
</ui:FluentWindow>
